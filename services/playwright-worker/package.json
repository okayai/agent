{
  "name": "@okay/playwright-worker",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "start": "node src/server.mjs",
    "check": "node --check src/server.mjs && node --check src/protocol.mjs",
    "test": "npm run test:unit && npm run test:e2e",
    "test:unit": "node --test test/protocol.test.mjs",
    "test:e2e": "node --test test/browser.e2e.test.mjs"
  },
  "dependencies": {
    "playwright": "1.61.1"
  },
  "engines": {
    "node": ">=20"
  }
}
